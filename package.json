{
  "name": "easydocs",
  "version": "1.0.0",
  "description": "Full-stack document management app",
  "author": "Jason Cahela <jpacahela@gmail.com>",
  "scripts": {
    "backend": "npm run dev -C backend",
    "frontend": "npm run dev -C frontend",
    "dev": "npm run backend & npm run frontend & wait",
    "test:backend": "npm test -C backend",
    "test:frontend": "npm test -C frontend",
    "test:backend:run": "npm test -C backend -- run",
    "test:frontend:run": "npm test -C frontend -- run",
    "test": "npm run test:backend:run && npm run test:frontend:run"
  },
  "workspaces": [
    "backend",
    "frontend"
  ],
  "devDependencies": {
    "vitest": "^4.0.18",
    "vite": "^7.3.1"
  }
}
